# PUHIS Backend Environment Variables
# Copy this file to .env and fill in your actual values
# 
# IMPORTANT: Never commit .env to version control!

# REQUIRED: OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OPTIONAL: Database
# For production: DATABASE_URL=postgresql://user:password@localhost:5432/puhis
# For development: DATABASE_URL=sqlite:///./puhis.db
# Leave empty for in-memory storage (testing only)
DATABASE_URL=

# OPTIONAL: Server Configuration
# HOST=0.0.0.0
# PORT=5000
