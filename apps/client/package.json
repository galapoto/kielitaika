{
  "name": "client",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck:yki-practice": "tsc --noEmit -p tsconfig.yki-practice.json",
    "typecheck:learning": "tsc --noEmit -p tsconfig.learning.json",
