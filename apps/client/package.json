    "validate:learning": "timeout 30s tsc --noEmit -p tsconfig.learning.json"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
