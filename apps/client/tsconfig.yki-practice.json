{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "types": ["node", "react"],
    "paths": {
      "@ui/*": ["../../packages/ui/*"],
      "@core/*": ["../../packages/core/*"],
      "react": ["node_modules/@types/react/index.d.ts"],
      "react-native": ["node_modules/react-native/types/index.d.ts"],
      "expo-av": ["node_modules/expo-av/build/index.d.ts"],
      "@react-native-async-storage/async-storage": [
        "node_modules/@react-native-async-storage/async-storage/lib/typescript/index.d.ts"
      ]
    }
  },
  "include": ["features/yki-practice/**/*"],
  "exclude": ["node_modules", "dist-web-prod"]
}
