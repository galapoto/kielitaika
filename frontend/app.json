{
  "expo": {
    "name": "KieliTaika",
    "slug": "kielitaika",
    "version": "0.0.0",
    "orientation": "portrait",
    "platforms": ["ios", "android", "web"],
    "sdkVersion": "54.0.0",
    "main": "index.js",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A3D62"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fi.kielitaika.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A3D62"
      },
      "permissions": ["AUDIO_RECORDING"],
      "package": "fi.kielitaika.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "kielitaika",
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Allow KieliTaika to access your microphone for speaking practice."
        }
      ]
    ]
  }
}
